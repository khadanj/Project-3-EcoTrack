# Copy this file to .env and fill in real values before starting the server.
# .env is gitignored so secrets stay out of the repo.

# MongoDB connection string. Use mongodb://localhost:27017 for the Docker setup
# in the README, or the connection string from Atlas in production.
MONGO_URI=mongodb://localhost:27017

# Any random string. Used to sign session cookies — change it in production.
SESSION_SECRET=replace-me-with-a-long-random-string

# Port for the Express server (frontend dev server proxies to 3001).
PORT=3001
